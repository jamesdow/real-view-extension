{
  "manifest_version": 3,
  "name": "Real View — AI Image Toggle",
  "version": "0.2.0",
  "description": "Flip AI-generated images off across any page so you only see real photos when hunting for references.",
  "permissions": ["storage", "contextMenus", "offscreen", "alarms"],
  "host_permissions": ["<all_urls>"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "cross_origin_embedder_policy": {
    "value": "require-corp"
  },
  "cross_origin_opener_policy": {
    "value": "same-origin"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Real View",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "options_page": "options/options.html",
  "web_accessible_resources": [
    {
      "resources": ["lib/transformers/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://*.pinterest.com/*", "https://pinterest.com/*"],
      "js": ["content/pinterest-hook.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/ai-domains-data.js", "content/detector.js", "content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ]
}
